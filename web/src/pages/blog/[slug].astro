---
import BaseLayout  from '../../layouts/BaseLayout.astro';
import Header      from '../../components/Header.astro';
import Footer      from '../../components/Footer.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props:  { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const {
  title,
  description,
  publishedDate,
  updatedDate,
  author,
  tags,
  image,
} = post.data;

const formattedDate = publishedDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const isoDate = publishedDate.toISOString();

const blogPostSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  url: new URL(`/blog/${post.slug}`, Astro.site).toString(),
  datePublished: isoDate,
  dateModified: updatedDate?.toISOString() ?? isoDate,
  author: {
    '@type': 'Person',
    name: author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'DrawBell',
    logo: { '@type': 'ImageObject', url: 'https://drawbell.kashifkhan.dev/favicon.svg' },
  },
  image: image
    ? new URL(image, Astro.site).toString()
    : 'https://drawbell.kashifkhan.dev/og-image.svg',
  keywords: tags.join(', '),
  inLanguage: 'en-US',
};
---

<BaseLayout
  {title}
  {description}
  type="article"
  publishedDate={isoDate}
  {author}
  {tags}
>
  <script type="application/ld+json" set:html={JSON.stringify(blogPostSchema)} slot="head" />

  <Header />

  <main class="min-h-screen bg-[#FAF8F5] dark:bg-[#0C0B0A] pt-28 pb-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">

      <!-- Back link -->
      <a
        href="/blog"
        class="inline-flex items-center gap-1.5 text-sm text-[#9B9189] hover:text-brand
               transition-colors duration-200 mb-10 font-mono"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        All posts
      </a>

      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mb-5">
        {tags.map((tag) => (
          <span class="text-xs font-mono px-2.5 py-1 rounded-full
                       border border-brand/30 text-brand bg-brand/5">
            {tag}
          </span>
        ))}
      </div>

      <!-- Title -->
      <h1 class="font-display font-extrabold text-4xl sm:text-5xl leading-[1.1] mb-6
                 text-[#1C1917] dark:text-[#F0EDE8]">
        {title}
      </h1>

      <!-- Meta -->
      <div class="flex flex-wrap items-center gap-4 mb-12
                  text-sm font-mono text-[#78716C] dark:text-[#9B9189]
                  border-b border-[#DDD5CB] dark:border-[#2E2B28] pb-8">
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          {author}
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8"  y1="2" x2="8"  y2="6"/>
            <line x1="3"  y1="10" x2="21" y2="10"/>
          </svg>
          <time datetime={isoDate}>{formattedDate}</time>
        </span>
        {updatedDate && (
          <span class="text-xs opacity-60">Updated {updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
        )}
      </div>

      <!-- Article content -->
      <article class="prose-drawbell">
        <Content />
      </article>

      <!-- Bottom nav -->
      <div class="mt-16 pt-8 border-t border-[#DDD5CB] dark:border-[#2E2B28]
                  flex items-center justify-between">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-sm text-brand font-medium
                 hover:gap-3 transition-all duration-200"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          Back to all posts
        </a>
        <a
          href="/download"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full
                 bg-brand text-white text-sm font-medium
                 hover:bg-[#F05A1A] transition-colors duration-200"
        >
          Download DrawBell
        </a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style is:global>
  /* ─── Blog prose styles ─────────────────────────── */
  .prose-drawbell {
    color: #9B9189;
    line-height: 1.8;
    font-size: 1rem;
  }

  :root:not(.dark) .prose-drawbell {
    color: #52433A;
  }

  .prose-drawbell h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 800;
    font-size: 1.75rem;
    line-height: 1.2;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: #F0EDE8;
  }
  :root:not(.dark) .prose-drawbell h2 { color: #1C1917; }

  .prose-drawbell h3 {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: #F0EDE8;
  }
  :root:not(.dark) .prose-drawbell h3 { color: #1C1917; }

  .prose-drawbell p {
    margin-bottom: 1.25rem;
  }

  .prose-drawbell strong {
    color: #F0EDE8;
    font-weight: 600;
  }
  :root:not(.dark) .prose-drawbell strong { color: #1C1917; }

  .prose-drawbell a {
    color: #D94A09;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose-drawbell a:hover { color: #F05A1A; }

  .prose-drawbell ul,
  .prose-drawbell ol {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .prose-drawbell li { margin-bottom: 0.5rem; }
  .prose-drawbell ul > li { list-style-type: disc; }
  .prose-drawbell ol > li { list-style-type: decimal; }

  .prose-drawbell blockquote {
    border-left: 3px solid #D94A09;
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: #78716C;
  }

  .prose-drawbell code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875em;
    background: rgba(217,74,9,0.08);
    color: #D94A09;
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .prose-drawbell pre {
    background: #131211;
    border: 1px solid #2E2B28;
    border-radius: 12px;
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }
  .prose-drawbell pre code {
    background: none;
    color: #F0EDE8;
    padding: 0;
  }

  .prose-drawbell table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }
  .prose-drawbell th {
    text-align: left;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #2E2B28;
    color: #D94A09;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .prose-drawbell td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #1A1816;
    vertical-align: top;
  }

  .prose-drawbell hr {
    border: none;
    border-top: 1px solid #2E2B28;
    margin: 2rem 0;
  }
</style>
