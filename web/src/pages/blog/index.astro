---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header     from '../../components/Header.astro';
import Footer     from '../../components/Footer.astro';
import BlogCard   from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf());
---

<BaseLayout
  title="Blog — DrawBell"
  description="Tips, guides, and deep-dives on the DrawBell alarm app — on-device AI, drawing challenges, alarm psychology, and more."
>
  <Header />

  <main class="min-h-screen bg-[#FAF8F5] dark:bg-[#0C0B0A] pt-28 pb-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <!-- Header -->
      <div class="mb-16">
        <p class="text-xs font-mono text-brand uppercase tracking-widest mb-3">Blog</p>
        <h1 class="font-display font-extrabold text-5xl sm:text-6xl
                   text-[#1C1917] dark:text-[#F0EDE8] mb-4">
          From the blog.
        </h1>
        <p class="text-lg text-[#78716C] dark:text-[#9B9189] max-w-xl">
          Sleep science, habit research, and morning strategies — with a drawing alarm that actually wakes you up.
        </p>
      </div>

      <!-- Posts grid -->
      {allPosts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {allPosts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug}
              publishedDate={post.data.publishedDate}
              tags={post.data.tags}
              image={post.data.image}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-24">
          <p class="text-[#78716C] dark:text-[#9B9189] text-lg">No posts yet — check back soon.</p>
        </div>
      )}
    </div>
  </main>

  <Footer />
</BaseLayout>
