        <div class="mt-8 text-center sm:hidden animate-on-scroll">
          <a href="/blog" class="text-sm text-brand font-medium">View all posts →</a>
        </div>
      </div>
    </section>
  )}

  <Footer />
</BaseLayout>

<style>
  /* ─── Phase transition animation ─────────────────── */
  .phase {
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .phase.hidden {
    display: none;
  }
  .phase.fade-out {
    opacity: 0;
    transform: translateY(-8px);
  }
  .phase.fade-in {
    animation: fadeInUp 0.4s ease both;
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0);    }
  }

  /* ─── Cat stroke draw animation ──────────────────── */
  @keyframes drawStroke {
    to { stroke-dashoffset: 0; }
  }
  .cat-stroke.drawing {
    animation: drawStroke var(--dur, 0.5s) var(--delay, 0s) ease-out both;
  }

  /* ─── Scroll reveal ───────────────────────────────── */
  .animate-on-scroll {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .animate-on-scroll.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  /* ═══════════════════════════════════════════
     Hero demo animation
  ═══════════════════════════════════════════ */
  const strokeData = [
    { id: 's0',  dur: '0.7s', delay: '0s'    },
    { id: 's1',  dur: '0.3s', delay: '0.6s'  },
    { id: 's2',  dur: '0.3s', delay: '0.85s' },
    { id: 's3',  dur: '0.25s', delay: '1.1s' },
    { id: 's4',  dur: '0.25s', delay: '1.3s' },
    { id: 's5',  dur: '0.2s', delay: '1.5s'  },
    { id: 's6',  dur: '0.2s', delay: '1.65s' },
    { id: 's7',  dur: '0.15s', delay: '1.8s' },
    { id: 's8',  dur: '0.15s', delay: '1.92s'},
    { id: 's9',  dur: '0.15s', delay: '2.04s'},
    { id: 's10', dur: '0.15s', delay: '2.16s'},
    { id: 's11', dur: '0.15s', delay: '2.28s'},
    { id: 's12', dur: '0.15s', delay: '2.4s' },
  ];

  function showPhase(id: string) {
    document.querySelectorAll<HTMLElement>('.phase').forEach((el) => {
      el.classList.add('hidden');
      el.classList.remove('fade-in');
    });
    const target = document.getElementById(id);
    if (!target) return;
    target.classList.remove('hidden');
    target.classList.add('fade-in');
    setTimeout(() => target.classList.remove('fade-in'), 400);
  }

  function resetStrokes() {
    strokeData.forEach(({ id }) => {
      const el = document.getElementById(id);
      if (!el) return;
      el.classList.remove('drawing');
      (el as SVGElement).getBoundingClientRect();
    });
  }

  function startDrawing() {
    resetStrokes();
    strokeData.forEach(({ id, dur, delay }) => {
      const el = document.getElementById(id);
      if (!el) return;
      (el as HTMLElement).style.setProperty('--dur', dur);
      (el as HTMLElement).style.setProperty('--delay', delay);
      el.classList.add('drawing');
    });
  }

  function runDemoLoop() {
    // Phase 1: alarm (0ms)
    showPhase('phase-alarm');

    // Phase 2: drawing challenge (2500ms)
    setTimeout(() => {
      showPhase('phase-draw');
      startDrawing();

      // Show "Analyzing…" after all strokes
      setTimeout(() => {
        const rt = document.getElementById('recognition-text');
        if (rt) rt.classList.remove('hidden');
      }, 2800);
    }, 2500);

    // Phase 3: success (6500ms)
    setTimeout(() => {
      const rt = document.getElementById('recognition-text');
      if (rt) rt.classList.add('hidden');
      showPhase('phase-success');
    }, 6500);

    // Reset and loop (9500ms)
    setTimeout(runDemoLoop, 9500);
  }

  // Start when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', runDemoLoop);
  } else {
    runDemoLoop();
  }

  /* ═══════════════════════════════════════════
     Scroll reveal with Intersection Observer
  ═══════════════════════════════════════════ */
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' },
  );

  document.querySelectorAll('.animate-on-scroll').forEach((el) => observer.observe(el));
</script>
