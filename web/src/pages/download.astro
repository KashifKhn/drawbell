---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Download DrawBell — Free Android Alarm App"
  description="Download DrawBell for Android. Always get the latest APK release. arm64 (most phones) or arm32 (older phones)."
>
  <Header />

  <main class="min-h-screen bg-[#FAF8F5] dark:bg-[#0C0B0A] pt-28 pb-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">

      <!-- Page header -->
      <div class="mb-12 text-center">
        <p class="text-xs font-mono text-brand uppercase tracking-widest mb-3">Android</p>
        <h1 class="font-display font-bold text-5xl sm:text-6xl text-[#1C1917] dark:text-[#F0EDE8] mb-4">
          Download DrawBell
        </h1>
        <p class="text-[#78716C] dark:text-[#9B9189] text-lg max-w-md mx-auto">
          Free. No account. No internet. Sideload the APK directly onto your Android device.
        </p>
      </div>

      <!-- Latest release card -->
      <div
        id="latest-card"
        class="relative rounded-2xl border border-brand/30 bg-brand/5 p-8 mb-6 overflow-hidden"
      >
        <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2
                      w-80 h-80 bg-brand/10 rounded-full blur-[80px]"></div>
        </div>

        <!-- Loading skeleton -->
        <div id="latest-loading" class="relative space-y-4 animate-pulse">
          <div class="flex items-center gap-3">
            <div class="h-6 w-24 bg-[#DDD5CB] dark:bg-[#2E2B28] rounded-full"></div>
            <div class="h-4 w-20 bg-[#DDD5CB] dark:bg-[#2E2B28] rounded-full"></div>
          </div>
          <div class="h-8 w-40 bg-[#DDD5CB] dark:bg-[#2E2B28] rounded-lg"></div>
          <div class="flex gap-3">
            <div class="h-12 w-52 bg-[#DDD5CB] dark:bg-[#2E2B28] rounded-full"></div>
            <div class="h-12 w-44 bg-[#DDD5CB] dark:bg-[#2E2B28] rounded-full"></div>
          </div>
        </div>

        <!-- Populated latest -->
        <div id="latest-content" class="relative hidden">
          <div class="flex flex-wrap items-center gap-3 mb-3">
            <span class="inline-flex items-center gap-1.5 text-xs font-mono font-medium
                         bg-brand text-white px-3 py-1 rounded-full">
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
              </svg>
              Latest
            </span>
            <span id="latest-version" class="text-[#78716C] dark:text-[#9B9189] font-mono text-sm"></span>
            <span id="latest-date" class="text-[#78716C] dark:text-[#9B9189] text-xs"></span>
          </div>
          <h2 id="latest-name" class="font-display font-bold text-2xl text-[#1C1917] dark:text-[#F0EDE8] mb-6"></h2>

          <!-- Primary download buttons -->
          <div id="latest-buttons" class="flex flex-wrap gap-3 mb-6"></div>

          <!-- Install tip -->
          <p class="text-xs text-[#78716C] dark:text-[#9B9189]">
            Not sure which to pick?
            <strong class="text-[#1C1917] dark:text-[#F0EDE8] font-medium">arm64 works on virtually all phones made after 2017.</strong>
          </p>
        </div>

        <!-- Error state -->
        <div id="latest-error" class="relative hidden text-center py-4">
          <p class="text-[#78716C] dark:text-[#9B9189] mb-4">Couldn't load releases. Check directly on GitHub.</p>
          <a
            href="https://github.com/KashifKhn/drawbell/releases/latest"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-full
                   bg-brand text-white text-sm font-medium
                   hover:bg-[#F05A1A] transition-colors"
          >
            View on GitHub
          </a>
        </div>
      </div>

      <!-- Install instructions -->
      <div class="rounded-2xl border border-[#DDD5CB] dark:border-[#2E2B28] bg-white dark:bg-[#141210] p-6 mb-12">
        <h3 class="font-display font-bold text-[#1C1917] dark:text-[#F0EDE8] text-base mb-4">How to install</h3>
        <ol class="space-y-3">
          {[
            ['Download', 'Tap the APK button above to download on your Android phone.'],
            ['Allow unknown sources', 'When prompted, allow installation from unknown sources in Settings.'],
            ['Install', 'Open the downloaded .apk file and tap Install.'],
            ['Done', 'Open DrawBell, set an alarm, and draw your way awake.'],
          ].map(([step, desc], i) => (
            <li class="flex gap-4">
              <span class="shrink-0 w-6 h-6 rounded-full bg-brand/15 border border-brand/30
                           text-brand text-xs font-mono font-bold
                           flex items-center justify-center">{i + 1}</span>
              <span class="text-sm text-[#78716C] dark:text-[#9B9189]">
                <strong class="text-[#1C1917] dark:text-[#F0EDE8] font-medium">{step} — </strong>{desc}
              </span>
            </li>
          ))}
        </ol>
      </div>

      <!-- All releases -->
      <div>
        <h2 class="font-display font-bold text-[#1C1917] dark:text-[#F0EDE8] text-xl mb-6 flex items-center gap-3">
          All Releases
          <a
            href="https://github.com/KashifKhn/drawbell/releases"
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs font-mono font-normal text-brand hover:underline"
          >
            GitHub →
          </a>
        </h2>

        <!-- Loading skeleton for releases list -->
        <div id="releases-loading" class="space-y-3 animate-pulse">
          {[1,2].map(() => (
            <div class="rounded-xl border border-[#DDD5CB] dark:border-[#2E2B28] bg-white dark:bg-[#141210] p-5">
              <div class="flex items-center justify-between mb-3">
                <div class="h-5 w-32 bg-[#DDD5CB] dark:bg-[#2E2B28] rounded-full"></div>
                <div class="h-4 w-20 bg-[#DDD5CB] dark:bg-[#2E2B28] rounded-full"></div>
              </div>
              <div class="flex gap-2">
                <div class="h-9 w-40 bg-[#DDD5CB] dark:bg-[#2E2B28] rounded-full"></div>
                <div class="h-9 w-36 bg-[#DDD5CB] dark:bg-[#2E2B28] rounded-full"></div>
              </div>
            </div>
          ))}
        </div>

        <!-- Populated releases list -->
        <div id="releases-list" class="space-y-3 hidden"></div>

        <div id="releases-error" class="hidden text-center py-8 text-[#78716C] dark:text-[#9B9189] text-sm">
          Failed to load releases.
          <a href="https://github.com/KashifKhn/drawbell/releases" target="_blank"
             rel="noopener noreferrer" class="text-brand hover:underline ml-1">
            View on GitHub →
          </a>
        </div>
      </div>

    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  interface GhAsset {
    name: string;
    browser_download_url: string;
    size: number;
    download_count: number;
    content_type: string;
  }

  interface GhRelease {
    name: string;
    tag_name: string;
    published_at: string;
    prerelease: boolean;
    draft: boolean;
    assets: GhAsset[];
  }

  function formatBytes(bytes: number): string {
    return (bytes / 1024 / 1024).toFixed(1) + ' MB';
  }

  function formatDate(iso: string): string {
    return new Date(iso).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    });
  }

  function apkLabel(name: string): string {
    if (name.includes('arm64')) return 'arm64 — Recommended';
    if (name.includes('arm32')) return 'arm32 — Older phones';
    return 'Universal APK';
  }

  function apkSublabel(name: string): string {
    if (name.includes('arm64')) return 'Most phones (2017+)';
    if (name.includes('arm32')) return 'Pre-2017 devices';
    return '';
  }

  function getApks(assets: GhAsset[]): GhAsset[] {
    return assets.filter(
      (a) => a.name.endsWith('.apk'),
    ).sort((a, b) => {
      if (a.name.includes('arm64')) return -1;
      if (b.name.includes('arm64')) return 1;
      return 0;
    });
  }

  function buildDownloadButton(asset: GhAsset, large: boolean): string {
    const label = apkLabel(asset.name);
    const sub = apkSublabel(asset.name);
    const size = formatBytes(asset.size);
    const isArm64 = asset.name.includes('arm64');

    if (large) {
      return `
        <a
          href="${asset.browser_download_url}"
          download
          class="inline-flex items-center gap-3 px-6 py-3.5 rounded-full font-medium text-sm
                 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2
                 focus-visible:ring-brand focus-visible:ring-offset-2
                 ${isArm64
                   ? 'bg-brand text-white hover:bg-[#F05A1A] shadow-[0_0_24px_rgba(217,74,9,0.35)] hover:shadow-[0_0_36px_rgba(217,74,9,0.5)]'
                   : 'border border-[#DDD5CB] dark:border-[#2E2B28] text-[#78716C] dark:text-[#9B9189] hover:border-brand/40 hover:text-[#1C1917] dark:hover:text-[#F0EDE8]'
                 }"
        >
          <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
          <span>
            <span class="block">${label}</span>
            <span class="block text-xs opacity-70">${sub ? sub + ' · ' : ''}${size}</span>
          </span>
        </a>`;
    }

    return `
      <a
        href="${asset.browser_download_url}"
        download
        class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full text-xs font-medium
               border transition-colors duration-200
               ${isArm64
                 ? 'border-brand/40 text-brand hover:bg-brand/10'
                  : 'border-[#DDD5CB] dark:border-[#2E2B28] text-[#78716C] dark:text-[#9B9189] hover:border-[#4E4B48] hover:text-[#1C1917] dark:hover:text-[#F0EDE8]'
               }"
      >
        <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        ${label} · ${size}
      </a>`;
  }

  function buildReleaseCard(release: GhRelease, isLatest: boolean): string {
    const apks = getApks(release.assets);
    const buttons = apks.map((a) => buildDownloadButton(a, false)).join('');

    return `
      <div class="rounded-xl border ${isLatest ? 'border-brand/20 bg-brand/5' : 'border-[#DDD5CB] dark:border-[#2E2B28] bg-white dark:bg-[#141210]'} p-5">
        <div class="flex flex-wrap items-center justify-between gap-2 mb-3">
          <div class="flex items-center gap-2.5">
            ${isLatest ? `<span class="text-xs font-mono bg-brand text-white px-2.5 py-0.5 rounded-full">Latest</span>` : ''}
            <span class="font-display font-bold text-[#1C1917] dark:text-[#F0EDE8]">${release.name}</span>
            <span class="font-mono text-xs text-[#78716C] dark:text-[#9B9189]">${release.tag_name}</span>
          </div>
          <span class="text-xs text-[#78716C] dark:text-[#9B9189]">${formatDate(release.published_at)}</span>
        </div>
        ${apks.length > 0
          ? `<div class="flex flex-wrap gap-2">${buttons}</div>`
          : `<p class="text-xs text-[#78716C] dark:text-[#9B9189]">No APK assets in this release.</p>`
        }
      </div>`;
  }

  async function loadReleases(): Promise<void> {
    try {
      const res = await fetch('https://api.github.com/repos/KashifKhn/drawbell/releases', {
        headers: { Accept: 'application/vnd.github+json' },
      });
      if (!res.ok) throw new Error(`GitHub API ${res.status}`);

      const releases: GhRelease[] = await res.json();
      const visible = releases.filter((r) => !r.draft && !r.prerelease);

      if (visible.length === 0) throw new Error('No releases found');

      const latest = visible[0];
      const apks = getApks(latest.assets);

      // Populate latest card
      const latestLoading = document.getElementById('latest-loading')!;
      const latestContent = document.getElementById('latest-content')!;
      latestLoading.classList.add('hidden');
      latestContent.classList.remove('hidden');

      document.getElementById('latest-version')!.textContent = latest.tag_name;
      document.getElementById('latest-date')!.textContent = formatDate(latest.published_at);
      document.getElementById('latest-name')!.textContent = latest.name;
      document.getElementById('latest-buttons')!.innerHTML =
        apks.map((a) => buildDownloadButton(a, true)).join('');

      // Populate all releases list
      const releasesLoading = document.getElementById('releases-loading')!;
      const releasesList = document.getElementById('releases-list')!;
      releasesLoading.classList.add('hidden');
      releasesList.classList.remove('hidden');
      releasesList.innerHTML = visible
        .map((r, i) => buildReleaseCard(r, i === 0))
        .join('');
    } catch {
      document.getElementById('latest-loading')!.classList.add('hidden');
      document.getElementById('latest-error')!.classList.remove('hidden');
      document.getElementById('releases-loading')!.classList.add('hidden');
      document.getElementById('releases-error')!.classList.remove('hidden');
    }
  }

  loadReleases();
</script>
