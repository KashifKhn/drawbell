---
import ThemeToggle from './ThemeToggle.astro';

const nav = [
  { label: 'How It Works', href: '/#how-it-works' },
  { label: 'The AI',       href: '/#ai-model'     },
  { label: 'Blog',         href: '/blog'           },
  { label: 'Download',     href: '/download'       },
];
---
<header
  id="site-header"
  class="
    fixed top-0 left-0 right-0 z-50
    transition-all duration-300
  "
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" aria-label="DrawBell home">
      <img
        src="/favicon.png"
        alt="DrawBell"
        height="36"
        class="h-9 w-auto"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
      {nav.map(({ label, href }) => (
        <a
          href={href}
          class="
            text-sm font-medium
            text-[#78716C] dark:text-[#9B9189]
            hover:text-brand dark:hover:text-brand
            transition-colors duration-200
          "
        >{label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <ThemeToggle />
      <a
        href="/download"
        class="
          hidden sm:inline-flex items-center gap-2
          px-4 py-2 rounded-full text-sm font-medium
          bg-brand text-white
          hover:bg-brand-600 dark:hover:bg-[#F05A1A]
          transition-colors duration-200
          focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2
        "
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        Download
      </a>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        aria-label="Open menu"
        aria-expanded="false"
        class="md:hidden w-10 h-10 flex flex-col items-center justify-center gap-1.5"
      >
        <span class="w-5 h-0.5 bg-current rounded transition-all duration-200" id="ham-1"></span>
        <span class="w-5 h-0.5 bg-current rounded transition-all duration-200" id="ham-2"></span>
        <span class="w-5 h-0.5 bg-current rounded transition-all duration-200 w-3" id="ham-3"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="
      hidden md:hidden
      border-t border-[#DDD5CB] dark:border-[#2E2B28]
      bg-[#FAF8F5]/95 dark:bg-[#0C0B0A]/95
      backdrop-blur-md px-4 py-4
    "
  >
    {nav.map(({ label, href }) => (
      <a
        href={href}
        class="
          block py-3 text-sm font-medium border-b
          border-[#DDD5CB] dark:border-[#2E2B28]
          text-[#1C1917] dark:text-[#F0EDE8]
          last:border-none
        "
      >{label}</a>
    ))}
    <a
      href="/download"
        px-4 py-3 rounded-xl text-sm font-medium
        bg-brand text-white
      "
    >Download APK</a>
  </div>
</header>

<script>
  const header = document.getElementById('site-header')!;
  const mobileBtn = document.getElementById('mobile-menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;

  // Scroll effect — add blur/bg after hero
  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      header.classList.add('is-scrolled');
    } else {
      header.classList.remove('is-scrolled');
    }
  }, { passive: true });

  // Mobile menu toggle
  mobileBtn.addEventListener('click', () => {
    const isOpen = mobileMenu.classList.toggle('hidden') === false;
    mobileBtn.setAttribute('aria-expanded', String(isOpen));
  });

  // Close mobile menu on link click
  mobileMenu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      mobileBtn.setAttribute('aria-expanded', 'false');
    });
  });
</script>
