---
// ThemeToggle.astro — icon button, no text
---
<button
  id="theme-toggle"
  aria-label="Toggle light/dark mode"
  class="
    w-10 h-10 rounded-full flex items-center justify-center
    border border-[#2E2B28] dark:border-[#2E2B28] border-[#DDD5CB]
    bg-transparent
    text-[#9B9189] dark:text-[#9B9189] hover:text-brand dark:hover:text-brand
    transition-colors duration-200
    focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand
  "
>
  <!-- Sun (shown in dark mode — click to go light) -->
  <svg
    id="icon-sun"
    class="hidden dark:block w-5 h-5"
    xmlns="http://www.w3.org/2000/svg"
    fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
  >
    <circle cx="12" cy="12" r="5"/>
    <line x1="12" y1="1"  x2="12" y2="3"/>
    <line x1="12" y1="21" x2="12" y2="23"/>
    <line x1="4.22" y1="4.22"   x2="5.64" y2="5.64"/>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
    <line x1="1"  y1="12" x2="3"  y2="12"/>
    <line x1="21" y1="12" x2="23" y2="12"/>
    <line x1="4.22" y1="19.78"  x2="5.64" y2="18.36"/>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
  </svg>
  <!-- Moon (shown in light mode — click to go dark) -->
  <svg
    id="icon-moon"
    class="block dark:hidden w-5 h-5"
    xmlns="http://www.w3.org/2000/svg"
    fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<script>
  const btn = document.getElementById('theme-toggle');
  const html = document.documentElement;

  btn?.addEventListener('click', () => {
    const isDark = html.classList.contains('dark');
    if (isDark) {
      html.classList.remove('dark');
      localStorage.setItem('theme', 'light');
    } else {
      html.classList.add('dark');
      localStorage.setItem('theme', 'dark');
    }
  });
</script>
