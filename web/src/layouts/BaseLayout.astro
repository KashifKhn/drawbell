---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

export interface Props {
  title:         string;
  description:   string;
  image?:        string;
  type?:         string;
  canonicalURL?: string;
  publishedDate?: string;
  author?:       string;
  tags?:         string[];
}

const {
  title,
  description,
  image       = '/og-image.svg',
  type        = 'website',
  canonicalURL = new URL(Astro.url.pathname, Astro.site).toString(),
  publishedDate,
  author = 'Kashif Khan',
  tags   = [],
} = Astro.props;

const siteName = 'DrawBell';
const fullTitle = title === siteName
  ? title
  : `${title} | ${siteName}`;

const ogImageUrl = new URL(image, Astro.site).toString();

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'DrawBell',
  url: 'https://drawbell.kashifkhan.dev',
  logo: 'https://drawbell.kashifkhan.dev/favicon.png',
  description:
    'DrawBell is an Android alarm app that uses on-device AI to verify your drawings before dismissing the alarm.',
  sameAs: [
    'https://github.com/KashifKhn/drawbell',
    'https://github.com/KashifKhn/quickdraw-345-classifier',
    'https://huggingface.co/zarqankhn/quickdraw-345-tflite',
  ],
};

const webSiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'DrawBell',
  url: 'https://drawbell.kashifkhan.dev',
  description,
};
---
<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#D94A09" />

  <!-- Primary SEO -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta name="robots"
        content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  {author && <meta name="author" content={author} />}

  <!-- Open Graph -->
  <meta property="og:type"        content={type} />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:title"       content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImageUrl} />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name"   content={siteName} />
  <meta property="og:locale"      content="en_US" />

  <!-- Twitter / X Cards -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImageUrl} />

  <!-- Article-specific -->
  {publishedDate && (
    <meta property="article:published_time" content={publishedDate} />
  )}
  {publishedDate && (
    <meta property="article:author" content={author} />
  )}
  {tags.map((tag) => (
    <meta property="article:tag" content={tag} />
  ))}

  <!-- Favicon -->
  <link rel="icon"             type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.png" />

  <!-- JSON-LD: Organization + WebSite -->
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />

  <!-- Named slot for page-specific head injections (JSON-LD, etc.) -->
  <slot name="head" />

  <!-- Theme initialiser — must run before paint to prevent flash -->
  <script is:inline>
    (function () {
      var stored = localStorage.getItem('theme');
      var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (stored === 'light' || (!stored && !prefersDark)) {
        document.documentElement.classList.remove('dark');
      } else {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
</head>

<body class="
  bg-[#FAF8F5] dark:bg-[#0C0B0A]
  text-[#1C1917]  dark:text-[#F0EDE8]
  font-sans antialiased
  transition-colors duration-300
">
  <slot />

  <Analytics />
</body>
</html>
